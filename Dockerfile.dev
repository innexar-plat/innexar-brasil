# Dev: apenas deps; o código é montado por volume. Hot-reload com npm run dev.
FROM node:20-alpine

WORKDIR /app

COPY package.json package-lock.json* ./
RUN npm ci

EXPOSE 3000
ENV NODE_ENV=development
ENV PORT=3000
ENV HOSTNAME=0.0.0.0
ENV NEXT_TELEMETRY_DISABLED=1

# Código é montado; instala deps se package.json mudar e sobe o dev server
CMD ["sh", "-c", "npm install && npm run dev"]
