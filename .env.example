# ─── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_DB=innexar_workspace
POSTGRES_USER=innexar
POSTGRES_PASSWORD=change_me_in_production_strong_password

# ─── FastAPI / JWT ────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=change_me_in_production_use_64_char_random_string_here_00000000
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Application ─────────────────────────────────────────────────────────────
APP_ENV=production
APP_PORT=8000

# ─── Website (Next.js) ───────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://innexar.com.br
NEXT_PUBLIC_SITE_NAME=Innexar
NEXT_PUBLIC_COLOR_PRIMARY=teal

# ─── Observability (optional) ────────────────────────────────────────────────
# LOG_LEVEL=info
# SENTRY_DSN=https://your-dsn@sentry.io/project-id
